  "type": "prestashop-module",
  "require": {
    "php": ">=8.1",
    "league/csv": "^9.0"
  },
  "require-dev": {
    "prestashop/php-dev-tools": "^4.0",
    "phpstan/phpstan": "^1.10"
  },
  "autoload": {
    "psr-4": {
      "B2B\\PriceImport\\": "src/"
    }
  },
  "config": {
